# The gate listens here; buying agents connect their MCP client to $PUBLIC_URL/mcp
PORT=8787
PUBLIC_URL=http://localhost:8787

# The merchant's UCP checkout endpoint the gate proxies to.
# NOTE: the sample merchant defaults to :3000, but AgentLens runs on :3000 in this
# environment. Run the merchant on :3100 (make its src honor $PORT, or free :3000).
# The sample merchant's better-sqlite3@9 also needs a node-24 prebuild swap to run.
MERCHANT_URL=http://localhost:3100

# AgentGate (run it on :4000 — it and the sample merchant both default to :3000)
AGENTGATE_URL=http://localhost:4000
AGENTGATE_API_KEY=replace-me
# HMAC secret returned by AgentGate createWebhook — used to verify decision webhooks
AGENTGATE_WEBHOOK_SECRET=

# Parked-session store (SQLite)
SQLITE_PATH=./agentgate-ucp.db

# AgentLens — tamper-evident, hash-chained evidence for every gated purchase.
# All optional: unset AGENTLENS_URL and the adapter runs exactly as before (no evidence).
# Local AgentLens on :3000 typically runs AUTH_DISABLED=true, so no key is needed there;
# set AGENTLENS_API_KEY (an als_* key with write+audit scope) when auth is on.
AGENTLENS_URL=http://localhost:3000
AGENTLENS_API_KEY=
# AgentGate agent token — only needed for Tier B signed (verified-agent) evidence packs.
AGENTLENS_AGENT_TOKEN=

# FormBridge — typed form handoff for `requires_buyer_input` escalations (gate point 3).
# ALL optional: leave FORMBRIDGE_URL unset and a buyer-input escalation is returned
# as the RAW UCP escalation (no form handoff), exactly as before.
#
# FORMBRIDGE_URL is the FormBridge HTTP API where the adapter registers intakes +
# creates submissions (server-to-server).
# FORMBRIDGE_PUBLIC_URL is the human-facing FORM-RENDERER host (the form-renderer /
# demo app), DISTINCT from the API. The resume link a human opens is built as
# `${FORMBRIDGE_PUBLIC_URL}/resume?token=<resumeToken>` (a rendered form page, NOT
# the JSON resume API). Defaults to FORMBRIDGE_URL only for a single-origin dev setup.
FORMBRIDGE_URL=http://localhost:8091
FORMBRIDGE_PUBLIC_URL=http://localhost:5173
# Bearer key for FormBridge writes; omit when FormBridge runs with auth disabled (dev default).
FORMBRIDGE_API_KEY=
# HMAC secret FormBridge signs answer-back webhooks with (X-FormBridge-Signature: sha256=...).
# Must match FormBridge's FORMBRIDGE_WEBHOOK_SECRET.
# REQUIRED whenever FORMBRIDGE_URL is set — the adapter FAILS TO START without it,
# because the answer-back webhook re-drives a payment and must be authenticated.
FORMBRIDGE_WEBHOOK_SECRET=replace-me-with-formbridge-webhook-secret
