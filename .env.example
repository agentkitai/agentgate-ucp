# The gate listens here; buying agents connect their MCP client to $PUBLIC_URL/mcp
PORT=8787
PUBLIC_URL=http://localhost:8787

# The merchant's UCP checkout endpoint the gate proxies to.
# NOTE: the sample merchant defaults to :3000, but AgentLens runs on :3000 in this
# environment. Run the merchant on :3100 (make its src honor $PORT, or free :3000).
# The sample merchant's better-sqlite3@9 also needs a node-24 prebuild swap to run.
MERCHANT_URL=http://localhost:3100

# AgentGate (run it on :4000 — it and the sample merchant both default to :3000)
AGENTGATE_URL=http://localhost:4000
AGENTGATE_API_KEY=replace-me
# HMAC secret returned by AgentGate createWebhook — used to verify decision webhooks
AGENTGATE_WEBHOOK_SECRET=

# Parked-session store (SQLite)
SQLITE_PATH=./agentgate-ucp.db

# AgentLens — tamper-evident, hash-chained evidence for every gated purchase.
# All optional: unset AGENTLENS_URL and the adapter runs exactly as before (no evidence).
# Local AgentLens on :3000 typically runs AUTH_DISABLED=true, so no key is needed there;
# set AGENTLENS_API_KEY (an als_* key with write+audit scope) when auth is on.
AGENTLENS_URL=http://localhost:3000
AGENTLENS_API_KEY=
# AgentGate agent token — only needed for Tier B signed (verified-agent) evidence packs.
AGENTLENS_AGENT_TOKEN=
