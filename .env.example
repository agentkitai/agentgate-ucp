# The gate listens here; buying agents connect their MCP client to $PUBLIC_URL/mcp
PORT=8787
PUBLIC_URL=http://localhost:8787

# The merchant's UCP checkout endpoint the gate proxies to (sample merchant = :3000)
MERCHANT_URL=http://localhost:3000

# AgentGate (run it on :4000 — it and the sample merchant both default to :3000)
AGENTGATE_URL=http://localhost:4000
AGENTGATE_API_KEY=replace-me
# HMAC secret returned by AgentGate createWebhook — used to verify decision webhooks
AGENTGATE_WEBHOOK_SECRET=

# Parked-session store (SQLite)
SQLITE_PATH=./agentgate-ucp.db
